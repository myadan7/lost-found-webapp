<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

    <header class="bg-blue-900 text-white p-4">
        <nav class="w-11/12 mx-auto flex items-center justify-between">
            <a href="/admin/dashboard" class="text-2xl font-bold text-white tracking-wide">Lost & Found</h1>
            <section class="flex gap-4 items-center">
                <span class="text-blue-200 text-sm">Welcome, <%= username %></span>
                <a href="/admin/logout" class="bg-blue-600 hover:bg-blue-600 text-white px-4 py-2 rounded-md text-sm">Logout</a>
                <a href="/admin/stats" class="text-blue-200 hover:text-white text-sm py-2">Stats</a>
            </section>
        </nav>
    </header>

    <main class="w-11/12 mx-auto py-8 flex-grow">

        <section class="mb-6">
            <h2 class="text-2xl font-bold text-blue-900 mb-1">Manage Items</h2>
            <p class="text-gray-500 text-sm">View, update and delete reported items</p>
        </section>

        <section class="bg-white p-4 rounded-lg shadow mb-6">
            <form method="GET" action="/admin/dashboard">
                <section class="flex flex-wrap gap-3 items-center">
                    <input type="text" name="search" aria-label="Search items by name or location" placeholder="Search by name or location"
                        value="<%= searchTerm %>"
                        class="border border-gray-300 rounded-md p-2 text-sm flex-grow">

                    <select name="category" class="border border-gray-300 rounded-md p-2 text-sm">
                        <option value="">All Categories</option>
                        <option value="electronics" <%= selectedCategory === 'electronics' ? 'selected' : '' %>>Electronics</option>
                        <option value="clothing" <%= selectedCategory === 'clothing' ? 'selected' : '' %>>Clothing</option>
                        <option value="bag" <%= selectedCategory === 'bag' ? 'selected' : '' %>>Bags</option>
                        <option value="keys" <%= selectedCategory === 'keys' ? 'selected' : '' %>>Keys</option>
                        <option value="wallet" <%= selectedCategory === 'wallet' ? 'selected' : '' %>>Wallet</option>
                        <option value="books" <%= selectedCategory === 'books' ? 'selected' : '' %>>Books</option>
                        <option value="other" <%= selectedCategory === 'other' ? 'selected' : '' %>>Other</option>
                    </select>

                    <select name="item_type" class="border border-gray-300 rounded-md p-2 text-sm">
                        <option value="">Lost & Found</option>
                        <option value="lost" <%= selectedType === 'lost' ? 'selected' : '' %>>Lost</option>
                        <option value="found" <%= selectedType === 'found' ? 'selected' : '' %>>Found</option>
                    </select>

                    <select name="status" aria-label="Update item status" class="border border-gray-300 rounded-md p-2 text-sm">
                        <option value="">All Status</option>
                        <option value="pending" <%= selectedStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="claimed" <%= selectedStatus === 'claimed' ? 'selected' : '' %>>Claimed</option>
                        <option value="returned" <%= selectedStatus === 'returned' ? 'selected' : '' %>>Returned</option>
                    </select>

                    <button type="submit" class="bg-blue-700 hover:bg-blue-800 text-white px-4 py-2 rounded-md text-sm">Search</button>
                    <a href="/admin/dashboard" class="text-blue-700 hover:text-blue-900 text-sm py-2">Clear</a>
                </section>
            </form>
        </section>

        <% if (items.length === 0) { %>
            <p class="text-gray-500 text-sm">No items to manage at the moment.</p>
        <% } else { %>

            <section class="bg-white rounded-lg shadow overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="bg-blue-900 text-white">
                        <tr>
                            <th class="px-4 py-3">ID</th>
                            <th class="px-4 py-3">Item Name</th>
                            <th class="px-4 py-3">Type</th>
                            <th class="px-4 py-3">Category</th>
                            <th class="px-4 py-3">Description</th>
                            <th class="px-4 py-3">Location</th>
                            <th class="px-4 py-3">Email</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Date</th>
                            <th class="px-4 py-3">Update</th>
                            <th class="px-4 py-3">Delete</th>
                            <th class="px-4 py-3">Notes</th>

                        </tr>
                    </thead>
                    <tbody>
                        <% items.forEach(item => { %>
                            <tr class="border-t border-gray-200 hover:bg-gray-50">
                                <td class="px-4 py-3"><%= item.id %></td>
                                <td class="px-4 py-3 font-medium"><%= item.item_name %></td>
                                <td class="px-4 py-3"><%= item.charAt(0).toUpperCase() + item.item_type.slice(1) %></td>
                                <td class="px-4 py-3"><%= item.category.charAt(0).toUpperCase() + item.category.slice(1) %></td>
                                <td class="px-4 py-3"><%= item.description %></td>
                                <td class="px-4 py-3"><%= item.location %></td>
                                <td class="px-4 py-3"><%= item.contact_email %></td>
                                <td class="px-4 py-3">
                                    
                                    <% if (item.status === 'pending') { %>
                                        
                                        <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full">Pending</span>
                                    <% }
                                     else if (item.status === 'claimed') { %>
                                        
                                        <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded-full">Claimed</span>
                                    <% } 
                                    else if (item.status === 'returned') { %>
                                        
                                        <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">Returned</span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3"><%= new Date(item.created_at).toLocaleDateString('en-GB') %></td>
                                <td class="px-4 py-3">
                                    <form action="/admin/update-status" method="POST">
                                        <input type="hidden" name="item_id" value="<%= item.id %>">
                                        <select name="status" onchange="this.form.submit()"
                                            
                                        class="border border-gray-300 rounded-md p-1 text-sm">
                                            <option value="pending" <%= item.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                            <option value="claimed" <%= item.status === 'claimed' ? 'selected' : '' %>>Claimed</option>
                                            <option value="returned" <%= item.status === 'returned' ? 'selected' : '' %>>Returned</option>
                                        </select>
                                    </form>
                                </td>
                                <td class="px-4 py-3">
                                    <form action="/admin/delete-item" method="POST">
                                        <input type="hidden" name="item_id" value="<%= item.id %>">
                                        <button type="submit"
                                        onclick="return confirm('Are you sure you want to delete this item?')"
                                        class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded-md text-xs">Delete</button>
                                    </form>
                                </td>
                                        <td class="px-4 py-3">
                                            <form action="/admin/save-notes" method="POST">
                                                <input type="hidden" name="item_id" value="<%= item.id%>">
                                                <textarea name="admin_notes" aria-label="Admin notes for this item" rows="2"
                                                class="border border-gray-300 rounded-md p-1 text-sm w-40"><%= item.admin_notes || '' %></textarea>
                                                <button type="submit" class="text-blue-700 text-xs my-1 block">Save</button>
                                            </form>
                                        </td>
                                </tr>
                            <% }); %>
                        </tbody>
                  </table>
                </section>

            <% } %>

    </main>

    <footer class="bg-blue-900 text-white text-center py-4 mt-8">
        <p class="text-xs text-blue-200">University Lost & Found &copy; 2026</p>
    </footer>

</body>
</html>