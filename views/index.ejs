<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, intial-scale=1.0">
    <title>Lost & Found App</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
    
    <header class="bg-blue-900 text-white p-4">
        <nav class="w-11/12 mx-auto flex items-center justify-between">
            <a href="/" class="text-2xl font-bold text-white tracking-wide">Lost & Found</h1>
            <section class="flex gap-4">
                <a href="/" class="<%= currentPage === 'home' ? 'text-white font-semibold' : 'text-blue-200 hover:text-white' %> text-sm py-2">Reported Items</a>
                <a href="/report" class="<%= currentPage === 'report' ? 'bg-blue-500 text-white' : 'bg-blue-600 hover:bg-blue-500 text-white' %> px-4 py-2 rounded-md text-sm">Report Item</a>
                <a href="/track" class="<%= currentPage === 'track' ? 'text-white font-semibold' : 'text-blue-200 hover:text-white' %> text-sm py-2">Track My Item</a>
                <a href="/admin/login" class="text-blue-200 hover:text-white text-sm py-2">Admin</a>
            </section>
        </nav>
    </header>


    <main class="w-11/12 mx-auto py-8 flex-grow">

        <section class="mb-6">
            <h2 class="text-2xl font-bold text-blue-900 mb-1">Reported Items</h2>
            <p class="text-gray-500 text-sm">Browse lost and found items reported on campus</p>
        </section>


        <section class="bg-white p-4 rounded-lg shadow mb-8">
            <form method="GET" action="/">
                <section class="flex flex-wrap gap-3" items-center">
                <input type="text" name="search" aria-label="Search items by name or location" placeholder="Search by name or location" value="<%= searchTerm %>"
                class="border border-gray-300 rounded-md p-2 text-sm flex-grow">

                <select name="category" aria-label="Filter by category" class="border border-gray-300 rounded-md p-2 text-sm">
                    <option value="">All Categories</option>
                    <option value="electronics" <%= selectedCategory === 'electronics' ? 'selected' : '' %>>Electronics</option>
                    <option value="clothing" <%= selectedCategory === 'clothing' ? 'selected' : '' %>>Clothing</option>
                    <option value="bag" <%= selectedCategory === 'bag' ? 'selected' : '' %>>Bags</option>
                    <option value="keys" <%= selectedCategory === 'keys' ? 'selected' : '' %>>Keys</option>
                    <option value="wallet" <%= selectedCategory === 'wallet' ? 'selected' : '' %>>Wallet</option>
                    <option value="books" <%= selectedCategory === 'books' ? 'selected' : '' %>>Books</option>
                    <option value="other" <%= selectedCategory === 'other' ? 'selected' : '' %>>Other</option>
                </select>

            <select name="item_type" aria-label="Filter by item type" class="border border-gray-300 rounded-md p-2 text-sm">
                <option value="">Lost & Found</option>
                    <option value="lost" <%= selectedType === 'lost' ? 'selected' : '' %>>Lost</option>
                    <option value="found" <%= selectedType === 'found' ? 'selected' : '' %>>Found</option>
            </select>
            
            <select name="status" aria-label="Filter by status" class="border border-gray-300 rounded-md p-2 text-sm">
                <option value="">All Status</option>
                    <option value="pending" <%= selectedStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                    <option value="claimed" <%= selectedStatus === 'claimed' ? 'selected' : '' %>>Claimed</option>
                    <option value="returned" <%= selectedStatus === 'returned' ? 'selected' : '' %>>Returned</option>
        </select>    

        <button type="submit" class="bg-blue-700 hover:bg-blue-800 text-white px-4 py-2 rounded-md text-sm">Search</button>
        <a href="/" class="text-blue-700 hover:text-blue-900 text-sm p-2">Clear</a>
            
            </section>
        </form>
    </section>

    <section class="flex flex-wrap gap-6">
        <% if (items.length === 0) { %>
        <p class="text-gray-500 text-sm">No items found</p>
        <% } else { %>

           <% items.forEach(item => { %>
                <section class="bg-white rounded-lg shadow p-5 w-full md:w-5/12 flex flex-col gap-3">

                    <h3 class="text-lg font-bold text-blue-900"><%= item.item_name.charAt(0).toUpperCase() + item.item_name.slice(1) %></h3>

                    <p class="text-sm text-gray-600"><span class="font-medium">Category:</span> <%= item.category.charAt(0).toUpperCase() + item.category.slice(1) %></p>
                    <p class="text-sm text-gray-600"><span class="font-medium">Reported as:</span> <%= item.item_type.charAt(0).toUpperCase() + item.item_type.slice(1) %></p>
                    <p class="text-sm text-gray-600"><span class="font-medium">Date Reported:</span> <%= new Date(item.created_at).toLocaleDateString('en-GB') %></p>

                    <section class="mt-auto pt-3">
                        <% if (item.status === 'pending') { %>
                            <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded-full">Pending</span>
                            <% } else if (item.status === 'claimed') { %>
                                <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-3 py-1 rounded-full">Claimed</span>
                                <% } else if (item.status === 'returned') { %>
                                <span class="bg-green-100 text-green-800 text-xs font-medium px-3 py-1 rounded-full">Returned</span>
                            <% } %>
                    </section>

                </section>
            <% }); %>

        <% } %>
            
    </section>

</main>

<footer class="bg-blue-900 text-white text-center py-3 mt-8">
    <section>
        <p class="text-sm text-blue-200">University Lost & Found &copy; 2026</p>
    </section>
</footer>
</body>
</html>