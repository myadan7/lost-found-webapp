<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

    <header class="bg-blue-900 text-white p-4">
        <nav class="w-11/12 mx-auto flex items-center justify-between">
            <a href="/" class="text-2xl font-bold text-white tracking-wide">Lost & Found</h1>
            <section class="flex gap-4">
                <a href="/report" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-md text-sm">Report Item</a>
                <a href="/track" class="text-blue-200 hover:text-white text-sm py-2">Track My Item</a>
                <a href="/admin/login" class="text-blue-200 hover:text-white text-sm py-2">Admin</a>
            </section>
        </nav>
    </header>

    <main class="w-11/12 mx-auto py-8 flex-grow">

        <section class="mb-6">
            <h2 class="text-2xl font-bold text-blue-900 mb-1">Admin Login</h2>
            <p class="text-gray-500 text-sm">Staff access only</p>
        </section>

        <section class="bg-white rounded-lg shadow p-6">

 
            <% if (typeof error !== 'undefined' && error) { %>
                <p class="text-red-500 text-sm mb-4"><%= error %></p>
            <% } %>

            <form action="/admin/login" method="POST">

                <section class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-1">Username</label>
                    <input type="text" name="username" required
                    aria-label="Admin username"
                    class="border border-gray-300 rounded-md p-2 text-sm w-full">
                </section>

                <section class="mb-6">
                    <label class="block text-sm font-bold text-gray-700 mb-1">Password</label>
                    <input type="password" name="password" required
                    aria-label="Admin password"
                        class="border border-gray-300 rounded-md p-2 text-sm w-full">
                </section>

                <section class="flex gap-4 items-center">
                    <button type="submit" class="bg-blue-700 hover:bg-blue-800 text-white px-6 py-2 rounded-md text-sm font-medium">Login</button>
                    <a href="/" class="text-gray-500 hover:text-gray-700 text-sm">Back to Home</a>
                </section>

            </form>
        </section>

    </main>

            <footer class="bg-blue-900 text-white text-center py-4 mt-8">
                <p class="text-xs text-blue-200">University Lost & Found &copy; 2026</p>
            </footer>

</body>
</html>