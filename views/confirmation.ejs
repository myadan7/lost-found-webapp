<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report Submitted</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

    <header class="bg-blue-900 text-white p-4">
        <nav class="w-11/12 mx-auto flex items-center justify-between">
            <a href="/" class="text-2xl font-bold text-white tracking-wide">Lost & Found</h1>
            <section class="flex gap-4">
                <a href="/" class="<%= currentPage === 'home' ? 'text-white font-semibold' : 'text-blue-200 hover:text-white' %> text-sm py-2">Reported Items</a>
                <a href="/report" class="<%= currentPage === 'report' ? 'bg-blue-500 text-white' : 'bg-blue-600 hover:bg-blue-500 text-white' %> px-4 py-2 rounded-md text-sm">Report Item</a>
                <a href="/track" class="<%= currentPage === 'track' ? 'text-white font-semibold' : 'text-blue-200 hover:text-white' %> text-sm py-2">Track My Item</a>
                <a href="/admin/login" class="text-blue-200 hover:text-white text-sm py-2">Admin</a>
            </section>
        </nav>
    </header>

    <main class="w-11/12 mx-auto py-8 flex-grow">

        <section class="mb-6">
            <h2 class="text-2xl font-bold text-blue-900 mb-1">Report Submitted</h2>
            <p class="text-gray-500 text-sm">Your item has been reported successfully</p>
        </section>

        <section class="bg-white rounded-lg shadow p-6">
            <section class="flex items-center gap-2 mb-6">
                <span class="bg-green-100 text-green-700 text-sm font-medium px-3 py-1 rounded-full">Success</span>
                <p class="text-sm text-gray-600">Thank you for submitting your report</p>
            </section>

            <section class="mb-6">
                <p class="text-sm font-bold text-gray-700 mb-1">Your Reference Number</p>
                <h3 class="text-3xl font-bold text-green-700"><%= refNumber %></h3>
                <p class="text-sm text-gray-500 mt-2">Keep this safe — you can use it to track your item status</p>
            </section>

            <section class="flex gap-4 items-center">
                <a href="/track" aria-label="Track your item status" class="bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-md text-sm font-medium">Track Your Item</a>
                <a href="/" aria-label="Go back to homepage" class="text-gray-500 hover:text-gray-700 text-sm">Back to Home</a>
            </section>

        </section>

    </main>


        <footer class="bg-blue-900 text-white text-center py-4 mt-8">
            <p class="text-xs text-blue-200">University Lost & Found &copy; 2026</p>
        </footer>

</body>
</html>