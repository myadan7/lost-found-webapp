<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Stats</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

    <header class="bg-blue-900 text-white p-4">
        <nav class="w-11/12 mx-auto flex items-center justify-between">
            <a href="/admin/dashboard" class="text-2xl font-bold text-white tracking-wide">Lost & Found</a>
            <section class="flex gap-4 items-center">
                <span class="text-blue-200 text-sm">Welcome, <%= username %></span>
                <a href="/admin/logout" class="text-blue-200 hover:text-white text-sm py-2">Logout</a>
                <a href="/admin/stats" class="<%= currentPage === 'stats' ? 'bg-blue-600 text-white px-4 py-2 rounded-md' : 'text-blue-200 hover:text-white py-2' %> text-sm">Stats</a>
                <a href="/admin/dashboard" class="<%= currentPage === 'dashboard' ? 'bg-blue-600 text-white px-4 py-2 rounded-md' : 'text-blue-200 hover:text-white py-2' %> text-sm">Dashboard</a>
            </section>
        </nav>
    </header>

    <main class="w-11/12 mx-auto py-8 flex-grow">

        <section class="mb-6">
            <h2 class="text-2xl font-bold text-blue-900 mb-1">Statistics</h2>
            <p class="text-gray-500 text-sm">Overview of lost and found activity on campus</p>
        </section>

        <section class="flex flex-wrap gap-6">

            <section class="bg-white rounded-lg shadow p-6 w-full md:w-5/12">
                <p class="text-sm text-gray-500 mb-1">Items Reported This Month</p>
                <h3 class="text-4xl font-bold text-blue-900"><%= monthly %></h3>
            </section>

            <section class="bg-white rounded-lg shadow p-6 w-full md:w-5/12">
                <p class="text-sm text-gray-500 mb-1">Total Items Ever Reported</p>
                <h3 class="text-4xl font-bold text-blue-900"><%= totalItems %></h3>
            </section>

            <section class="bg-white rounded-lg shadow p-6 w-full md:w-5/12">
                <p class="text-sm text-gray-500 mb-1">Most Common Category</p>
                <h3 class="text-4xl font-bold text-blue-900 capitalize"><%= topCategory %></h3>
            </section>

            <section class="bg-white rounded-lg shadow p-6 w-full md:w-5/12">
                <p class="text-sm text-gray-500 mb-1">Most Common Location</p>
                <h3 class="text-4xl font-bold text-blue-900"><%= topLocation %></h3>
            </section>

            <section class="bg-white rounded-lg shadow p-6 w-full md:w-5/12">
                <p class="text-sm text-gray-500 mb-1">Items Successfully Returned</p>
                <h3 class="text-4xl font-bold text-green-600"><%= returnedPercentage %>%</h3>
            </section>

        </section>

    </main>

    <footer class="bg-blue-900 text-white text-center py-4 mt-8">
        <p class="text-xs text-blue-200">University Lost & Found &copy; 2026</p>
    </footer>

</body>
</html>